
# Redis connection
REDIS_URL=redis://:YOURPASSWORD@127.0.0.1:6379/0

# Auth secrets
JWT_SECRET=super-secret-mail-ninja-key-123
ADMIN_JWT_SECRET=super_secret_admin_jwt_key_9999
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SecurePassword123!

# Stripe billing
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
FRONTEND_URL=https://yourdomain.com

# ── SMTP Verification Settings ────────────────────────────────────────────────

# Your sending domain used in HELO/EHLO and MAIL FROM during SMTP probes.
# Should match the PTR (reverse DNS) record of your server IP for best deliverability.
HELO_DOMAIN=mail.yourdomain.com

# Comma-separated list of your server IPs for SMTP source-IP rotation (optional).
# Add more IPs to distribute SMTP load and reduce per-IP blacklisting risk.
# Leave unset to use the server's default outbound IP (single-IP mode).
# SMTP_SOURCE_IPS=185.x.x.1,185.x.x.2,185.x.x.3

# Max SMTP verification requests per domain per minute (default: 5).
# Increase only if you have multiple IPs configured above.
# SMTP_RATE_LIMIT_PER_MIN=5

# Database (default: SQLite for dev, use PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost/email_verifier
